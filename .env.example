# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this only in your production secrets, not in the repo.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://https://grameen-craft-7w3gbrwlf-javatava.vercel.app"

# DATABASE_URL: Required for PostgreSQL database integration.
# Provide your PostgreSQL connection string here.
DATABASE_URL="postgresql://user:password@host:port/dbname"

# VITE_API_URL: Required for separate frontend hosting (like Vercel)
# Points to your Render backend root URL without the `/api` suffix.
# Example: https://grameencraft-backend.onrender.com
VITE_API_URL="https://your-backend-url.onrender.com"

